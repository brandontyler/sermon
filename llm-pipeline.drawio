<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="PSR Sermon Scoring Pipeline — LLM Model Calls" style="text;fontSize=18;fontStyle=1;fontColor=#333333;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="680" height="40" as="geometry"/>
    </mxCell>

    <!-- ═══════ INPUT LAYER ═══════ -->
    <mxCell id="upload_audio" value="Audio Upload&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;MP3 / WAV / M4A&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="160" y="70" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="upload_text" value="Text Upload&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;TXT / DOCX / MD&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="700" y="70" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- ═══════ WAVE 1: PRE-PROCESSING (Audio path) ═══════ -->
    <mxCell id="wave1_label" value="Wave 1 — Pre-processing (parallel)" style="text;fontSize=11;fontStyle=5;fontColor=#999999;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="155" width="250" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="transcribe" value="Azure AI Speech&lt;br&gt;&lt;b&gt;Transcribe&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;fullText, segments, WPM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="80" y="190" width="180" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="parselmouth" value="Parselmouth&lt;br&gt;&lt;b&gt;Audio Analysis&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;pitch, intensity, pauses&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="300" y="190" width="180" height="70" as="geometry"/>
    </mxCell>

    <!-- Text path: extract + build segments -->
    <mxCell id="extract_text" value="Extract Text&lt;br&gt;&lt;b&gt;Build Segments&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;paragraphs, est. 140 WPM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="700" y="190" width="160" height="70" as="geometry"/>
    </mxCell>

    <!-- Merge point -->
    <mxCell id="transcript_ready" value="Transcript Ready" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="420" y="310" width="180" height="40" as="geometry"/>
    </mxCell>

    <!-- ═══════ WAVE 2: LLM SCORING (5 parallel calls) ═══════ -->
    <mxCell id="wave2_label" value="Wave 2 — LLM Scoring (5 calls in parallel)" style="text;fontSize=11;fontStyle=5;fontColor=#999999;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="380" width="300" height="20" as="geometry"/>
    </mxCell>

    <!-- Pass 1: Biblical (o4-mini) -->
    <mxCell id="pass1_box" value="Pass 1: Biblical Analysis" style="swimlane;startSize=26;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="420" width="190" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="pass1_model" value="&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;o4-mini&lt;/b&gt;&lt;/font&gt;" style="text;fontSize=11;align=center;" vertex="1" parent="pass1_box">
      <mxGeometry x="35" y="30" width="120" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="pass1_m1" value="Biblical Accuracy (25%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pass1_box">
      <mxGeometry x="10" y="55" width="170" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="pass1_m2" value="Time in the Word (25%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pass1_box">
      <mxGeometry x="10" y="92" width="170" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="pass1_m3" value="Passage Focus (10%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pass1_box">
      <mxGeometry x="10" y="129" width="170" height="30" as="geometry"/>
    </mxCell>

    <!-- Pass 2: Structure (GPT-5-mini) -->
    <mxCell id="pass2_box" value="Pass 2: Structure &amp; Content" style="swimlane;startSize=26;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="250" y="420" width="190" height="170" as="geometry"/>
    </mxCell>
    <mxCell id="pass2_model" value="&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;GPT-5-mini&lt;/b&gt;&lt;/font&gt;" style="text;fontSize=11;align=center;" vertex="1" parent="pass2_box">
      <mxGeometry x="35" y="30" width="120" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="pass2_m1" value="Clarity (10%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;" vertex="1" parent="pass2_box">
      <mxGeometry x="10" y="55" width="170" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="pass2_m2" value="Application (10%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;" vertex="1" parent="pass2_box">
      <mxGeometry x="10" y="92" width="170" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="pass2_m3" value="Engagement (10%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=10;" vertex="1" parent="pass2_box">
      <mxGeometry x="10" y="129" width="170" height="30" as="geometry"/>
    </mxCell>

    <!-- Pass 3: Delivery (GPT-5-nano) -->
    <mxCell id="pass3_box" value="Pass 3: Delivery" style="swimlane;startSize=26;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="470" y="420" width="190" height="140" as="geometry"/>
    </mxCell>
    <mxCell id="pass3_model" value="&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;GPT-5-nano&lt;/b&gt;&lt;/font&gt;" style="text;fontSize=11;align=center;" vertex="1" parent="pass3_box">
      <mxGeometry x="35" y="30" width="120" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="pass3_m1" value="Delivery (5%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="pass3_box">
      <mxGeometry x="10" y="55" width="170" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="pass3_m2" value="Emotional Range (5%)" style="rounded=1;whiteSpace=wrap;fillColor=#FFFFFF;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="pass3_box">
      <mxGeometry x="10" y="92" width="170" height="30" as="geometry"/>
    </mxCell>

    <!-- Classify Sermon (GPT-5-nano) -->
    <mxCell id="classify" value="Classify Sermon&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;GPT-5-nano&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;expository / topical / survey&lt;br&gt;title, pastor, main passage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="690" y="420" width="190" height="80" as="geometry"/>
    </mxCell>

    <!-- Classify Segments (GPT-5-nano) -->
    <mxCell id="segments" value="Classify Segments&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;GPT-5-nano&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;scripture / teaching / application&lt;br&gt;anecdote / illustration / prayer&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="690" y="520" width="190" height="80" as="geometry"/>
    </mxCell>

    <!-- ═══════ WAVE 3: POST-PROCESSING ═══════ -->
    <mxCell id="wave3_label" value="Wave 3 — Post-processing (sequential)" style="text;fontSize=11;fontStyle=5;fontColor=#999999;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="630" width="300" height="20" as="geometry"/>
    </mxCell>

    <mxCell id="normalize" value="Normalize Scores&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;sermon-type weighting + confidence adj.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="160" y="660" width="220" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="composite" value="Compute Composite PSR&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;weighted average of 8 categories&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="420" y="660" width="220" height="50" as="geometry"/>
    </mxCell>

    <mxCell id="summary" value="Generate Summary&lt;br&gt;&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;GPT-5-nano&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#666&quot;&gt;summary, strengths, improvements&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="680" y="650" width="200" height="70" as="geometry"/>
    </mxCell>

    <!-- Store -->
    <mxCell id="cosmos" value="Store in Cosmos DB" style="shape=cylinder3;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;size=12;" vertex="1" parent="1">
      <mxGeometry x="420" y="760" width="180" height="60" as="geometry"/>
    </mxCell>

    <!-- ═══════ EDGES ═══════ -->

    <!-- Upload Audio to Wave 1 -->
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="upload_audio" target="transcribe" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="upload_audio" target="parselmouth" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Upload Text to extract -->
    <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="upload_text" target="extract_text" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Wave 1 to merge -->
    <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="transcribe" target="transcript_ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e4b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;" edge="1" source="parselmouth" target="transcript_ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="extract_text" target="transcript_ready" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Transcript to 5 parallel LLM calls -->
    <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.15;exitY=1;exitDx=0;exitDy=0;" edge="1" source="transcript_ready" target="pass1_box" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="447" y="390"/>
          <mxPoint x="125" y="390"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.35;exitY=1;exitDx=0;exitDy=0;" edge="1" source="transcript_ready" target="pass2_box" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="483" y="380"/>
          <mxPoint x="345" y="380"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="transcript_ready" target="pass3_box" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="510" y="375"/>
          <mxPoint x="565" y="375"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.85;exitY=1;exitDx=0;exitDy=0;" edge="1" source="transcript_ready" target="classify" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="573" y="370"/>
          <mxPoint x="785" y="370"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=1;exitDx=0;exitDy=0;" edge="1" source="transcript_ready" target="segments" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="600" y="365"/>
          <mxPoint x="670" y="365"/>
          <mxPoint x="670" y="560"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Audio metrics to Pass 3 -->
    <mxCell id="e_audio" value="audio metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;fontStyle=2;fontSize=9;fontColor=#999999;" edge="1" source="parselmouth" target="pass3_box" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="390" y="280"/>
          <mxPoint x="565" y="280"/>
          <mxPoint x="565" y="420"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Wave 2 to normalize -->
    <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="pass1_box" target="normalize" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="125" y="620"/>
          <mxPoint x="270" y="620"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="pass2_box" target="normalize" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="345" y="615"/>
          <mxPoint x="270" y="615"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="pass3_box" target="normalize" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="565" y="610"/>
          <mxPoint x="270" y="610"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Classify to normalize (sermon type affects weighting) -->
    <mxCell id="e14" value="sermon type" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;fontStyle=2;fontSize=9;fontColor=#999999;" edge="1" source="classify" target="normalize" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="900" y="460"/>
          <mxPoint x="940" y="460"/>
          <mxPoint x="940" y="685"/>
          <mxPoint x="380" y="685"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Normalize to composite -->
    <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="normalize" target="composite" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Composite to summary -->
    <mxCell id="e16" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="composite" target="summary" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Summary + composite to Cosmos -->
    <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="summary" target="cosmos" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="780" y="740"/>
          <mxPoint x="510" y="740"/>
        </Array>
      </mxGeometry>
    </mxCell>
    <mxCell id="e18" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="segments" target="cosmos" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="960" y="560"/>
          <mxPoint x="960" y="750"/>
          <mxPoint x="510" y="750"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Legend -->
    <mxCell id="legend_box" value="Legend" style="swimlane;startSize=22;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="760" width="310" height="80" as="geometry"/>
    </mxCell>
    <mxCell id="leg1" value="&lt;font color=&quot;#CC0000&quot;&gt;&lt;b&gt;Red text&lt;/b&gt;&lt;/font&gt; = LLM model name (6 total LLM calls)" style="text;fontSize=10;align=left;" vertex="1" parent="legend_box">
      <mxGeometry x="10" y="26" width="280" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="leg2" value="Dashed lines = optional / graceful degradation" style="text;fontSize=10;align=left;" vertex="1" parent="legend_box">
      <mxGeometry x="10" y="44" width="280" height="16" as="geometry"/>
    </mxCell>
    <mxCell id="leg3" value="(%) = weight in composite PSR score" style="text;fontSize=10;align=left;" vertex="1" parent="legend_box">
      <mxGeometry x="10" y="60" width="280" height="16" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
