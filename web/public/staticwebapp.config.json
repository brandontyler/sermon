{
  "routes": [
    {
      "route": "/.auth/login/github",
      "statusCode": 404
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/_next/static/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/admin/feeds",
      "allowedRoles": ["admin"],
      "rewrite": "/admin/feeds.html"
    },
    {
      "route": "/admin/manage",
      "allowedRoles": ["admin"],
      "rewrite": "/admin/manage.html"
    },
    {
      "route": "/admin",
      "allowedRoles": ["admin"],
      "rewrite": "/admin.html"
    },
    {
      "route": "/church-admin",
      "allowedRoles": ["admin"],
      "rewrite": "/church-admin.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/dashboard.html"
    },
    {
      "route": "/calculations",
      "rewrite": "/calculations.html"
    },
    {
      "route": "/churches",
      "rewrite": "/churches.html"
    },
    {
      "route": "/sermons",
      "rewrite": "/sermons.html"
    },
    {
      "route": "/sermons/*.txt",
      "rewrite": "/sermons/placeholder.txt"
    },
    {
      "route": "/sermons/*",
      "rewrite": "/sermons/placeholder.html"
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer",
      "statusCode": 302
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/favicon.ico"]
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  }
}
