{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/_next/static/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/admin",
      "rewrite": "/admin.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/dashboard.html"
    },
    {
      "route": "/calculations",
      "rewrite": "/calculations.html"
    },
    {
      "route": "/churches",
      "rewrite": "/churches.html"
    },
    {
      "route": "/church-admin",
      "rewrite": "/church-admin.html"
    },
    {
      "route": "/sermons",
      "rewrite": "/sermons.html"
    },
    {
      "route": "/sermons/*.txt",
      "rewrite": "/sermons/placeholder.txt"
    },
    {
      "route": "/sermons/*",
      "rewrite": "/sermons/placeholder.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/favicon.ico"]
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  }
}
