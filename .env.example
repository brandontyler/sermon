# PSR — Pastor Sermon Rating
# Copy to .env and fill in values. For local dev, fetch keys via az CLI:
#   az cognitiveservices account keys list --name psr-speech-dev -g rg-sermon-rating-dev --query key1 -o tsv
#   az cognitiveservices account keys list --name psr-openai-dev -g rg-sermon-rating-dev --query key1 -o tsv

# Azure AI Speech (fast transcription API)
SPEECH_KEY=
SPEECH_ENDPOINT=https://eastus2.api.cognitive.microsoft.com

# Azure OpenAI
OPENAI_KEY=
OPENAI_ENDPOINT=https://psr-openai-dev.openai.azure.com
OPENAI_API_VERSION=2025-01-01-preview

# Cosmos DB
COSMOS_CONNECTION_STRING=

# Blob Storage (also used as AzureWebJobsStorage by Functions runtime)
STORAGE_CONNECTION_STRING=

# Porkbun (DNS management for howwas.church)
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

# Azure region
AZURE_REGION=eastus2
AZURE_RESOURCE_GROUP=rg-sermon-rating-dev
